#! /usr/bin/env python
import re

def build(bld):

    sources = []
    includes = []

    platform = bld.env.PLATFORM

    if platform in ('x86_64-macos','arm64-macos'):
        sources  = bld.path.ant_glob(['*.c', 'cocoa/*.m'])
        includes = '. cocoa'
    elif platform in ('arm64-ios', 'x86_64-ios'):
        sources  = bld.path.ant_glob(['*.c', 'ios/*.m', 'ios/app/*.m'])
        includes = '. ios'
    elif re.match('arm.*?android', platform):
        sources  = bld.path.ant_glob(['*.c', 'android/*.c'])
        sources  = [source for source in sources if source.name != 'android_window_no_api.c']
        includes = '. android'
    elif platform in ['x86_64-linux', 'arm64-linux']:
        sources  = bld.path.ant_glob(['*.c', 'x11/*.c'])
        includes = '. x11'
    elif 'win32' in platform:
        sources  = bld.path.ant_glob(['*.c', 'win32/*.c'])
        includes = '. win32'
    elif 'web' in platform:
        sources  = bld.path.ant_glob('web/*.c')
        includes = '. web'

    dmglfw = bld.stlib(features     = 'c',
                       source       = sources,
                       includes     = includes,
                       target       = 'dmglfw')

    if re.match('arm.*?android', platform):
        vulkan_sources = bld.path.ant_glob(['*.c', 'android/*.c'])
        vulkan_sources = [source for source in vulkan_sources if source.name not in ('android_util.c', 'android_glext.c', 'android_window_gl.c', 'image.c')]
        dmglfw_vulkan = bld.stlib(features     = 'c',
                                  source       = vulkan_sources,
                                  includes     = includes,
                                  defines      = ['DMGLFW_NO_GL'],
                                  target       = 'dmglfw_vulkan')
