#version 140

in highp vec3 position;
in lowp vec4 color;

uniform vertex_uniforms {
    highp mat4 mtx_world_view_proj;
};

out lowp vec4 var_color;

void main() {
    // Straight alpha: blending uses glBlendFunc(SRC_ALPHA, ONE_MINUS_SRC_ALPHA).
    // Premultiplying rgb by a here double-applies alpha and makes lines/grids too faint.
    var_color = color;
    gl_Position = mtx_world_view_proj * vec4(position, 1.0);
}
