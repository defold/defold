#version 140

in highp vec3 position;
in mediump vec2 texcoord;
in mediump float page_index;

uniform vertex_uniforms {
    highp mat4 mtx_world_view_proj;
};

out mediump vec2 var_texcoord;
out mediump float var_page_index;

void main() {
    var_texcoord = texcoord;
    var_page_index = page_index;
    gl_Position = mtx_world_view_proj * vec4(position, 1.0);
}
