function M.get_commands()
    return {
        editor.command({
            label = "Test",
            id = "defold.test",
            locations = {"Edit"},
            run = function()
                print_targeted_game_project_checks()
                print_targeted_test_collection_checks()
                print_targeted_test_go_checks()
                print_targeted_test_gui_checks()
                print_targeted_test_particlefx_checks()
                print_targeted_test_tilemap_checks()
                print_targeted_test_tilesource_checks()
                print_targeted_test_input_binding_checks()
                print_targeted_editor_script_resource_checks()
            end
        })
    }
end

return M
