#! /usr/bin/env python

import waflib.Options
from waf_dynamo import find_feature_files

def options(opt):
    opt.load('waf_dynamo')

def configure(conf):
    conf.load('waf_dynamo')

def build(bld):
    source_files = bld.path.ant_glob(['common/*.cpp'])
    platform_source_files, _ = find_feature_files(bld, 'testmain', bld.env.PLATFORM, required = False)
    source_files += platform_source_files

    b = bld.stlib(features     = 'c cxx',
                  includes     = ['.', '..'],
                  source       = source_files,
                  target       = 'testmain')

    bld.install_files('${PREFIX}/include/testmain', 'common/testmain.h')

    if not waflib.Options.options.skip_build_tests:
        bld.recurse('test')
