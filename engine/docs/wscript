#! /usr/bin/env python

VERSION='0.1'
APPNAME='docs'

srcdir = '.'
blddir = 'build'

import waflib.Utils
import sys, os, re, fnmatch
import shutil
import waflib.Options
import waf_dynamo
import TestContext
from waf_dynamo import apidoc_extract_task

test_context = None

def init(ctx):
    global test_context
    if 'build' in waflib.Options.commands:
        test_context = TestContext.create_test_context()

def configure(conf):
    conf.recurse('src')
    pass

def clean(conf):
    # Clean up src
    files = os.listdir('src')
    for filename in fnmatch.filter(files, '*.apidoc_'):
        os.remove(os.path.join('src', filename))

def build(bld):
    global test_context
    # Clean up src
    files = os.listdir('src')
    for filename in fnmatch.filter(files, '*.apidoc_'):
        os.remove(os.path.join('src', filename))

    apidoc_extract_task(bld, "../crash/src/",                   ["script_crash.cpp"])
    apidoc_extract_task(bld, "../ddf/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../dlib/src/",                    ["dmsdk"])
    apidoc_extract_task(bld, "../dlib/src/",                    ["cs/dmsdk"])
    apidoc_extract_task(bld, "../engine/proto/",                ["engine/engine_ddf.proto"])
    apidoc_extract_task(bld, "../engine/src/",                  ["engine_doc.h", "script/script_engine.cpp"])
    apidoc_extract_task(bld, "../engine/src/",                  ["dmsdk"])
    apidoc_extract_task(bld, "../extension/src/",               ["dmsdk"])
    apidoc_extract_task(bld, "../extension/src/",               ["cs/dmsdk"])
    apidoc_extract_task(bld, "../font/src/",                    ["dmsdk"])
    apidoc_extract_task(bld, "../gameobject/proto/",            ["gameobject/gameobject_ddf.proto"])
    apidoc_extract_task(bld, "../gameobject/src/gameobject/",   ["gameobject_script.cpp"])
    apidoc_extract_task(bld, "../gameobject/src/",              ["dmsdk"])
    apidoc_extract_task(bld, "../gamesys/proto/",               ["gamesys"])
    apidoc_extract_task(bld, "../gamesys/src/",                 ["dmsdk"])
    apidoc_extract_task(bld, "../gamesys/src/gamesys/",         ["scripts"])
    apidoc_extract_task(bld, "../gamesys/src/",                 ["gamesys/box2d"])
    apidoc_extract_task(bld, "../graphics/src/",                ["dmsdk"])
    apidoc_extract_task(bld, "../gui/src/",                     ["gui_script.cpp"])
    apidoc_extract_task(bld, "../gui/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../hid/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../liveupdate/src/",              ["liveupdate.h"])
    apidoc_extract_task(bld, "../lua/src/",                     [""])
    apidoc_extract_task(bld, "../lua/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../lua/src/",                     ["cs/dmsdk"])
    apidoc_extract_task(bld, "../physics/src/",                 ["dmsdk"])
    apidoc_extract_task(bld, "../platform/src/",                ["dmsdk"])
    apidoc_extract_task(bld, "../profiler/src/",                ["profiler.cpp"])
    apidoc_extract_task(bld, "../render/proto/",                ["render"])
    apidoc_extract_task(bld, "../render/src/",                  ["render/render_script.cpp", "render/render_script_camera.cpp"])
    apidoc_extract_task(bld, "../render/src/",                  ["dmsdk"])
    apidoc_extract_task(bld, "../resource/src/",                ["dmsdk"])
    apidoc_extract_task(bld, "../rig/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../script/",                      ["src"])
    apidoc_extract_task(bld, "../script/src/",                  ["dmsdk"])
    apidoc_extract_task(bld, "../script/src/",                  ["luasocket"])
    apidoc_extract_task(bld, "../script/src/",                  ["script"])
    apidoc_extract_task(bld, "../sdk/src/",                     ["dmsdk"])
    apidoc_extract_task(bld, "../sdk/src/",                     ["cs/dmsdk"])
    apidoc_extract_task(bld, "../sound/src/",                   ["dmsdk"])

    # Find all the generated .apidoc files in build/ and copy them to src/
    for root, dirs, files in os.walk('build'):
        for filename in fnmatch.filter(files, '*.apidoc'):
            shutil.copy(os.path.join(root, filename), os.path.join("src", filename))

    # Convert all src/*.apidoc files into their final formats (json, sdoc, md etc)
    bld.recurse('src')
    TestContext.initialize_test_context(test_context, bld)

def options(opt):
    opt.recurse('src')
    opt.load('waf_dynamo')
    opt.add_option('--skip-tests', action='store_true', default=False, dest='skip_tests', help='skip unit tests')

def shutdown(self):
    if not TestContext.is_valid(test_context):
        return
    if not getattr(waflib.Options.options, 'skip_tests', False):
        python_path = os.environ.get('PYTHONPATH', '')
        os.environ['PYTHONPATH'] = 'src' + os.pathsep + 'build/default/src' + os.pathsep + python_path
        ret = os.system('python %s' % 'src/test/test_script_doc.py')
        if ret != 0:
            sys.exit(1)
