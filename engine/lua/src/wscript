#! /usr/bin/env python
import os

from waflib import Options
from waf_dynamo import dmsdk_add_files

def options(opt):
    pass

def configure(conf):
    conf.env.append_value('INCLUDES', "../src")
    conf.recurse('test')

def build(bld):
    bld.recurse('lua')

    bld.stlib(features = 'c',
              source   = 'dlua/dlua.c',
              includes = '. lua',
              use      = 'lua_static',
              defines  = ['DM_DLUA_BACKEND_LUA'],
              target   = 'dlua')

    if not 'web' in bld.env.PLATFORM:
        luajit_include = os.path.join(bld.env.DYNAMO_HOME, 'ext/include/luajit-2.1')

        bld.stlib(features = 'c',
                  source   = 'dlua/dlua.c',
                  includes = ['.', luajit_include],
                  defines  = ['DM_DLUA_BACKEND_LUAJIT'],
                  target   = 'dluajit')

    dmsdk_add_files(bld, '${PREFIX}/sdk/include/dmsdk', 'dmsdk')
    dmsdk_add_files(bld, '${PREFIX}/sdk/cs/dmsdk', 'cs/dmsdk')

    if not Options.options.skip_build_tests:
        bld.add_group() # until the csharp rule correctly uses "use" for dependencies
        bld.recurse('test')
