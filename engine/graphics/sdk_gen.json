                    "VertexAttributeStepFunction": "VertexStepFunction",
                    "HGraphicsContext": "HContext",
                    "GraphicsCreateParams": "ContextParams",
                    "GraphicsContextParamsInitialize": "ContextParamsInitialize",
                    "GraphicsNewContext": "NewContext",
                    "GraphicsDeleteContext": "DeleteContext",
                    "GraphicsInstallAdapter": "InstallAdapter",
                    "GraphicsBeginFrame": "BeginFrame",
                    "GraphicsFlip": "Flip",
                    "GraphicsCloseWindow": "CloseWindow",
                    "GraphicsFinalize": "Finalize",
                    "VertexStreamDeclarationNewStep": "NewVertexStreamDeclaration",
                    "VertexStreamDeclarationNew": "NewVertexStreamDeclaration",
                    "VertexStreamDeclarationAddHash": "AddVertexStream",
                    "VertexStreamDeclarationAdd": "AddVertexStream",
                    "VertexStreamDeclarationDelete": "DeleteVertexStreamDeclaration",
                    "VertexDeclarationNewStride": "NewVertexDeclaration",
                    "VertexDeclarationNew": "NewVertexDeclaration",
