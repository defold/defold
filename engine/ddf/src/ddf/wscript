#! /usr/bin/env python

import os, sys
from waf_dynamo import copy_file_task

def build(bld):
    proto_include_path = bld.env['DYNAMO_HOME'] + '/ext/include'
    proto_python_path = bld.env['DYNAMO_HOME'] + '/ext/lib/python'

    proto_plugin_src = "%s/%s" % (proto_include_path, 'google/protobuf/compiler/plugin.proto')
    proto_plugin_pb2_src = "%s/%s" % (proto_python_path, 'google/protobuf/compiler/plugin_pb2.py')
    copy_file_task(bld, proto_plugin_src, 'copy_plugin.proto')
    copy_file_task(bld, proto_plugin_pb2_src)

    bld(rule   = '${PROTOC} --python_out=. -I . -I %s ${SRC}' % (proto_include_path),
        source = 'plugin.proto',
        after  = 'copy_plugin.proto',
        shell  = True)

    bld.install_files('${PREFIX}/lib/python',
                      bld.path.find_or_declare('plugin_pb2.py'))

    bld.add_group()

    bld.stlib(features = 'cxx ddf',
        includes = '../.. ..',
        source = 'ddf_extensions.proto ddf_math.proto ddf_struct.proto ddf.cpp ddf_load.cpp ddf_save.cpp ddf_inputbuffer.cpp ddf_util.cpp ddf_message.cpp ddf_loadcontext.cpp ddf_outputstream.cpp',
        proto_gen_cc = True,
        proto_compile_cc = True,
        proto_gen_py = True,
        protoc_includes = '..',
        target = 'ddf')

    bld.add_group() # depend on the proto outputs

    bld.install_files('${PREFIX}/lib/python/ddf',
                      bld.path.find_or_declare('ddf_extensions_pb2.py'))

    ddf_noasan_source = [bld.path.find_resource(proto).change_ext('.cpp')
                         for proto in 'ddf_extensions.proto ddf_math.proto ddf_struct.proto'.split()]
    ddf_noasan_source += 'ddf.cpp ddf_load.cpp ddf_save.cpp ddf_inputbuffer.cpp ddf_util.cpp ddf_message.cpp ddf_loadcontext.cpp ddf_outputstream.cpp'.split()

    bld.stlib(features = 'cxx skip_asan',
        includes = '../.. ..',
        source = ddf_noasan_source,
        target = 'ddf_noasan')

    bld.install_files('${PREFIX}/include/ddf', 'ddf.h')

def configure(conf):
    pass
